{
  "name": "evoultimate",
  "version": "1.0.0",
  "description": "evo Ultimate – Bond Origination and Home Loan Experts",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack",
    "bundle": "npm run jekyll",
    "jekyll": "jekyll build --baseurl ''",
    "serve": "jekyll serve --baseurl ''",
    "trace": "jekyll serve --trace --baseurl ''",
    "optimize-images": "node scripts/optimize-images.js",
    "favicon:generate": "node scripts/generate-favicons.js",
    "prebuild": "npm run optimize-images && npm run favicon:generate",
    "prejekyll": "npm run build"
  },
  "author": "Eben Roux / Pieter Oosthuizen",
  "license": "ISC",
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^5.9.0",
    "bootstrap": "^4.3.1",
    "css-loader": "^4.2.2",
    "cross-env": "^10.0.0",
    "expose-loader": "^1.0.0",
    "file-loader": "^6.1.0",
    "jquery": "^3.4.1",
    "mini-css-extract-plugin": "^0.11.0",
    "optimize-css-assets-webpack-plugin": "^5.0.3",
    "popper.js": "^1.15.0",
    "style-loader": "^1.0.0",
    "terser-webpack-plugin": "^4.1.0",
    "url-loader": "^4.1.0",
    "webpack": "^4.40.2",
    "webpack-cli": "^3.3.9",
    "sass": "^1.77.8",
    "sass-loader": "^9.0.3",
    "jquery.easing": "^1.4.1",
    "sharp": "^0.33.0"
  },
  "dependencies": {}
